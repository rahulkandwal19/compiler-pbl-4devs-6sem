GLOBAL:
    IMPORT "xyz";
    PRINTLN("Hello! WORD")

SOURCES:
    SOURCE Hello_L 
        PRINTLN("Hello! ","From SOURCE") 
    ;
    
EVENTS:
    Event Hello_E
       PRINTLN("Hello! ","From EVENT")
    ;

OBSERVERS:
    OBSERVER Hello_O 
        INT X = 1
        PRINTLN("Hello! ","From OBSERVER", X);
        X = 2
        PRINTLN("Hello! ","From OBSERVER", 2)
    ;

FUNCTIONS:

    FUNCTION print_hello()
        PRINTLN("Hello WORD!")
    ;